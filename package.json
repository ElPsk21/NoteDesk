{
  "name": "notedesk",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/renderer.js --bundle --outfile=src/renderer.bundle.js --platform=browser --format=iife --external:electron",
    "start": "npm run build && electron .",
    "dev": "esbuild src/renderer.js --bundle --outfile=src/renderer.bundle.js --platform=browser --format=iife --external:electron --watch",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "marked": "^18.0.5"
  },
  "build": {
    "appId": "com.notedesk.app",
    "productName": "NoteDesk",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
